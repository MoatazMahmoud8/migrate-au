# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

GEMINI_API_KEY=your_gemini_api_key_here
REVENUECAT_API_KEY_IOS=your_revenuecat_ios_api_key_here
REVENUECAT_API_KEY_ANDROID=your_revenuecat_android_api_key_here

# Sentry crash reporting
# Get DSN at https://sentry.io → Project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=
# Auth token for sourcemap upload during EAS builds (scopes: project:releases, org:read)
# Store as EAS secret, not in .env: eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
SENTRY_AUTH_TOKEN=
