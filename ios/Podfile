require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")

# For apps using Expo modules
require File.join(File.dirname(`node --print "require.resolve('expo-build-properties/package.json')"`), "scripts/autolinking")

platform :ios, '13.4'
target 'migration_au' do
  use_expo_modules!
  config = use_native_modules!

  use_react_native!(
    path: config[:reactNativePath],
    to_relativize: [config[:reactNativePath]],
    hermes_enabled: true,
    fabric_enabled: false
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )
    __apply_Xcode_12_5_M1_post_install_workaround(installer)
    
    # Fix Firebase Swift pod dependencies - enable modular headers
    installer.pods_project.targets.each do |target|
      if target.name == 'FirebaseAuth' ||
         target.name == 'FirebaseCoreInternal' ||
         target.name == 'FirebaseFirestore' ||
         target.name == 'GoogleUtilities' ||
         target.name == 'FirebaseCore'
        target.build_configurations.each do |config|
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= '$(inherited)'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << ' FIREBASE_SDK_USING_MODULAR_HEADERS=1'
          config.build_settings['SWIFT_VERSION'] = '5.0'
        end
      end
    end

    # Enable module maps for all pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_ENABLE_OBJC_WEAK'] = 'YES'
      end
    end
  end
end
